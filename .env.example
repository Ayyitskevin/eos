EOS_PORT=8410
EOS_HOST=127.0.0.1
EOS_BASE_URL=http://localhost:8410
EOS_DATA_DIR=./data
EOS_SECRET_KEY=change-me-in-production
EOS_ADMIN_PASSWORD=change-me
EOS_SITE_NAME=Eos Photography
EOS_CONTACT_EMAIL=hello@example.com
EOS_TIMEZONE=America/New_York
EOS_DEFAULT_TURNAROUND_HOURS=24
EOS_COOKIE_SECURE=false
EOS_WEB_MAX_PX=2400
EOS_THUMB_MAX_PX=480
EOS_JPEG_QUALITY=88
EOS_JOB_WORKERS=2
EOS_MIN_FREE_GB=2
EOS_STRIPE_SECRET_KEY=
EOS_STRIPE_WEBHOOK_SECRET=
EOS_GMAIL_USER=
EOS_GMAIL_APP_PASSWORD=
EOS_CONTACT_REPLY_TO=
# Multi-tenant SaaS (set both true for hosted platform)
EOS_SAAS_MODE=true
EOS_SIGNUP_ENABLED=true
EOS_BASE_DOMAIN=eos.yourdomain.com
EOS_BILLING_ENFORCE=true
EOS_BOOTSTRAP_EMAIL=
EOS_SEQUENCE_TICK_SECONDS=60
EOS_INTEGRATION_TICK_SECONDS=120
EOS_GOOGLE_CLIENT_ID=
EOS_GOOGLE_CLIENT_SECRET=
EOS_GOOGLE_REDIRECT_URI=http://localhost:8410/oauth/google/callback
EOS_DROPBOX_APP_KEY=
EOS_DROPBOX_APP_SECRET=
EOS_DROPBOX_REDIRECT_URI=http://localhost:8410/oauth/dropbox/callback
EOS_STRIPE_PLATFORM_SECRET_KEY=
EOS_STRIPE_PLATFORM_WEBHOOK_SECRET=
EOS_STRIPE_PRICE_STARTER=
EOS_STRIPE_PRICE_PRO=
# Optional platform fee on Connect client payments (percent, e.g. 2.5)
EOS_STRIPE_APPLICATION_FEE_PERCENT=0
EOS_TOKEN_ENCRYPTION_KEY=

EOS_SIGNUP_RATE_LIMIT=5
EOS_TWILIO_ACCOUNT_SID=
EOS_TWILIO_AUTH_TOKEN=
EOS_TWILIO_FROM_NUMBER=
EOS_SIGNUP_RATE_WINDOW_SEC=3600
EOS_SENTRY_DSN=
EOS_SENTRY_ENVIRONMENT=production
EOS_PLATFORM_ADMIN_EMAILS=
EOS_DEMO_ENABLED=true
EOS_GOOGLE_ADMIN_REDIRECT_URI=http://localhost:8410/oauth/google/admin/callback

# Object storage (production SaaS — S3 or Cloudflare R2)
EOS_S3_BUCKET=
EOS_S3_REGION=auto
EOS_S3_ENDPOINT=
EOS_S3_ACCESS_KEY=
EOS_S3_SECRET_KEY=
EOS_S3_PREFIX=eos

# Postgres (optional — SQLite default)
EOS_DATABASE_URL=