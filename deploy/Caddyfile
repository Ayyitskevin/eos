# Eos — Caddy reverse proxy with automatic HTTPS (multi-tenant SaaS)
# Copy to /etc/caddy/Caddyfile after deploy/install.sh
#
# 1. Replace eos.example.com with your apex (marketing + signup)
# 2. Wildcard *.eos.example.com routes tenant subdomains
# 3. Set EOS_BASE_DOMAIN=eos.example.com in /opt/eos/.env
# 4. DNS: A/AAAA for apex AND *.eos.example.com → this server

{
	email you@example.com
}

eos.example.com {
	reverse_proxy 127.0.0.1:8410
	request_body {
		max_size 64MB
	}
}

*.eos.example.com {
	reverse_proxy 127.0.0.1:8410
	request_body {
		max_size 64MB
	}
}