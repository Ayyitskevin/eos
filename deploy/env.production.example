# Eos production — multi-tenant SaaS (edit before going live)
EOS_PORT=8410
EOS_HOST=127.0.0.1
EOS_BASE_URL=https://eos.yourdomain.com
EOS_DATA_DIR=/opt/eos/data
EOS_SECRET_KEY=change-me-in-production
EOS_ADMIN_PASSWORD=change-me-strong-password
EOS_SITE_NAME=Eos
EOS_CONTACT_EMAIL=hello@yourdomain.com
EOS_TIMEZONE=America/New_York
EOS_COOKIE_SECURE=true
EOS_BOOTSTRAP_EMAIL=platform@yourdomain.com
EOS_JOB_WORKERS=4
EOS_MIN_FREE_GB=5

# --- Multi-tenant SaaS (recommended) ---
EOS_SAAS_MODE=true
EOS_SIGNUP_ENABLED=true
EOS_BASE_DOMAIN=eos.yourdomain.com
EOS_BILLING_ENFORCE=true
EOS_SIGNUP_INVITE_ONLY=true
EOS_PLATFORM_ADMIN_EMAILS=platform@yourdomain.com

# Transactional email (Postmark recommended for SaaS)
EOS_EMAIL_PROVIDER=postmark
EOS_POSTMARK_API_KEY=
EOS_POSTMARK_FROM_EMAIL=notifications@yourdomain.com
EOS_PLATFORM_EMAIL_NAME=Eos

# Platform subscriptions (studios pay Eos)
EOS_STRIPE_PLATFORM_SECRET_KEY=
EOS_STRIPE_PLATFORM_WEBHOOK_SECRET=
EOS_STRIPE_PRICE_STARTER=
EOS_STRIPE_PRICE_PRO=
EOS_STRIPE_APPLICATION_FEE_PERCENT=0

# Legacy solo Stripe key (optional — SaaS uses Connect per tenant)
EOS_STRIPE_SECRET_KEY=
EOS_STRIPE_WEBHOOK_SECRET=

# Object storage (S3 or Cloudflare R2) — required at scale
EOS_S3_BUCKET=
EOS_S3_REGION=auto
EOS_S3_ENDPOINT=
EOS_S3_ACCESS_KEY=
EOS_S3_SECRET_KEY=
EOS_S3_PREFIX=eos

# Postgres (optional — SQLite default; set when scaling past ~25 studios)
# EOS_DATABASE_URL=postgresql://eos:secret@127.0.0.1:5432/eos

# Email
EOS_GMAIL_USER=
EOS_GMAIL_APP_PASSWORD=

# OAuth integrations
EOS_GOOGLE_CLIENT_ID=
EOS_GOOGLE_CLIENT_SECRET=
EOS_GOOGLE_REDIRECT_URI=https://eos.yourdomain.com/oauth/google/callback
EOS_GOOGLE_ADMIN_REDIRECT_URI=https://eos.yourdomain.com/oauth/google/admin/callback
EOS_DROPBOX_APP_KEY=
EOS_DROPBOX_APP_SECRET=
EOS_DROPBOX_REDIRECT_URI=https://eos.yourdomain.com/oauth/dropbox/callback

# SMS (optional)
EOS_TWILIO_ACCOUNT_SID=
EOS_TWILIO_AUTH_TOKEN=
EOS_TWILIO_FROM_NUMBER=

# Observability
EOS_SENTRY_DSN=
EOS_SENTRY_ENVIRONMENT=production
EOS_DEMO_ENABLED=true