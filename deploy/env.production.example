EOS_PORT=8410
EOS_HOST=127.0.0.1
EOS_BASE_URL=https://eos.example.com
EOS_DATA_DIR=/opt/eos/data
EOS_SECRET_KEY=change-me-in-production
EOS_ADMIN_PASSWORD=change-me-strong-password
EOS_SITE_NAME=Eos Photography
EOS_CONTACT_EMAIL=hello@example.com
EOS_TIMEZONE=America/New_York
EOS_COOKIE_SECURE=true
EOS_BOOTSTRAP_EMAIL=owner@example.com
EOS_JOB_WORKERS=2
EOS_MIN_FREE_GB=2

# SaaS (optional)
EOS_SAAS_MODE=false
EOS_SIGNUP_ENABLED=false
EOS_BASE_DOMAIN=
EOS_BILLING_ENFORCE=false

# Integrations (optional)
EOS_GMAIL_USER=
EOS_GMAIL_APP_PASSWORD=
EOS_STRIPE_SECRET_KEY=
EOS_STRIPE_WEBHOOK_SECRET=
EOS_GOOGLE_CLIENT_ID=
EOS_GOOGLE_CLIENT_SECRET=
EOS_GOOGLE_REDIRECT_URI=https://eos.example.com/oauth/google/callback
EOS_DROPBOX_APP_KEY=
EOS_DROPBOX_APP_SECRET=
EOS_DROPBOX_REDIRECT_URI=https://eos.example.com/oauth/dropbox/callback
EOS_TWILIO_ACCOUNT_SID=
EOS_TWILIO_AUTH_TOKEN=
EOS_TWILIO_FROM_NUMBER=